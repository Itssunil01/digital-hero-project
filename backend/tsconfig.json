{
 "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,            
    "noImplicitAny": false ,     
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}